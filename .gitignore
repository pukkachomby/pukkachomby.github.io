# ------------------------------------------------------------------------------
# Hugo Build & Cache Outputs
# ------------------------------------------------------------------------------
# Default build output directory
/public/

# Local server resources and cache (e.g. processed images, Tailwind builds)
/resources/_gen/
.hugo_build.lock

# Hugo module cache (if using Hugo Modules)
/_vendor/

# ------------------------------------------------------------------------------
# Node.js / Tailwind CSS (Blowfish dependencies)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ------------------------------------------------------------------------------
# Environment & Sensitive Files
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# ------------------------------------------------------------------------------
# Operating System & IDE Artifacts
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini

# Editors & IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.netrwhist